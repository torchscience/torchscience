//   impl_type    - fully qualified traits struct type
// ============================================================================

#ifndef TORCHSCIENCE_GRAPHICS
#define TORCHSCIENCE_GRAPHICS(X) \
    X(cook_torrance, 5, torchscience::impl::graphics::shading::CookTorranceImpl)
#endif
