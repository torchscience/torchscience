#!/bin/bash
# Pre-commit hook for torch-science
# This hook runs Ruff (Python) and clang-format (C++/CUDA/Metal) on staged files
#
# To install this hook, run: ./hooks/install-hooks.sh
# Or manually: ln -sf ../../hooks/pre-commit .git/hooks/pre-commit

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 Running pre-commit checks..."

# Check if we have any staged files
if git diff --cached --name-only | grep -q .; then
    :
else
    echo "${GREEN}✓${NC} No staged files to check"
    exit 0
fi

# Track if any checks failed
FAILED=0

# ============================================================================
# Python files - Ruff
# ============================================================================
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$PYTHON_FILES" ]; then
    echo "📝 Checking Python files with Ruff..."

    # Check if ruff is installed
    if ! command -v ruff &> /dev/null; then
        echo "${RED}✗${NC} Ruff is not installed. Install with: pip install ruff"
        FAILED=1
    else
        # Run ruff check with --fix to auto-fix issues
        if ! echo "$PYTHON_FILES" | xargs ruff check --fix; then
            echo "${RED}✗${NC} Ruff linting failed"
            FAILED=1
        else
            echo "${GREEN}✓${NC} Ruff linting passed"
        fi

        # Run ruff format
        if ! echo "$PYTHON_FILES" | xargs ruff format; then
            echo "${RED}✗${NC} Ruff formatting failed"
            FAILED=1
        else
            echo "${GREEN}✓${NC} Ruff formatting passed"
        fi

        # Re-stage files that were modified by ruff
        echo "$PYTHON_FILES" | xargs git add
    fi
fi

# ============================================================================
# C++/CUDA/Metal files - clang-format
# ============================================================================
CPP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|hpp|h|c|cu|cuh|mm)$' || true)

if [ -n "$CPP_FILES" ]; then
    echo "🔧 Checking C++/CUDA/Metal files with clang-format..."

    # Check if clang-format is installed
    if ! command -v clang-format &> /dev/null; then
        echo "${RED}✗${NC} clang-format is not installed."
        echo "Install with: brew install clang-format (macOS)"
        echo "            : apt-get install clang-format (Linux)"
        FAILED=1
    else
        # Format files
        for file in $CPP_FILES; do
            if [ -f "$file" ]; then
                clang-format -i "$file"
            fi
        done

        echo "${GREEN}✓${NC} clang-format completed"

        # Re-stage files that were modified by clang-format
        echo "$CPP_FILES" | xargs git add
    fi
fi

# ============================================================================
# Final check
# ============================================================================
if [ $FAILED -ne 0 ]; then
    echo ""
    echo "${RED}✗ Pre-commit checks failed!${NC}"
    echo "Please fix the issues and try again."
    exit 1
fi

echo ""
echo "${GREEN}✓ All pre-commit checks passed!${NC}"
exit 0
